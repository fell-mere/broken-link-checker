{# Extends the main control panel layout for consistent CP structure #}
{% extends "_layouts/cp.twig" %}

{% import "_includes/forms.twig" as forms %}

{# Page title shown in the browser tab and CP header #}
{% set title = "Broken Links Ignore List"|t('broken-links') %}

{# Breadcrumb back to the main Broken Links page #}
{% set crumbs = [
    { label: "Broken Links"|t('broken-links'), url: cpUrl('brokenlinks') },
] %}

{% block content %}
    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('brokenlinks/broken-links/settings') }}
        {{ redirectInput('brokenlinks/settings') }}

        {{ forms.textareaField({
            label: "Ignored URL patterns"|t('broken-links'),
            instructions: "One pattern per line. Any broken link URL containing the pattern will be skipped. Example: twitter.com, facebook.com."|t('broken-links'),
            id: 'ignoredUrlPatterns',
            name: 'ignoredUrlPatterns',
            rows: 10,
            value: settings.ignoredUrlPatterns|join("\n"),
        }) }}

        <div class="buttons">
            <input type="submit" class="btn submit" value="{{ 'Save'|t('broken-links') }}">
        </div>
    </form>
{% endblock %}
