{% if latestScan %}
    <div class="broken-links-widget">
        <div class="widget-status">
            <div class="details">
                {{ "Last scan:"|t('broken-links') }} {{ latestScan.endTime ? latestScan.endTime|datetime('short') : "In progress"|t('broken-links') }}
            </div>
        </div>

        {% if brokenLinks|length > 0 %}
            <div class="widget-links">
                <h3>{{ "Recent Broken Links"|t('broken-links') }}</h3>
                <ul>
                    {% for link in brokenLinks %}
                        <li>
                            <a href="{{ link.url }}" target="_blank" class="link-url" title="{{ link.url }}">{{ link.url|length > 40 ? link.url|slice(0, 40) ~ '...' : link.url }}</a>
                            <div class="link-details">
                                <span class="status-pill">{{ link.status }}</span>
                                <span class="occurrence">{{ "Lots of broken links"|t('broken-links') }}</span>
                            </div>
                        </li>
                    {% endfor %}
                </ul>
                
                {% if totalBrokenLinks > limit %}
                    <a href="{{ cpUrl('brokenlinks') }}" class="view-all">
                        {{ "View all {count} broken links"|t('broken-links', {count: totalBrokenLinks}) }}
                    </a>
                {% endif %}
            </div>
        {% endif %}

        <a href="{{ cpUrl('brokenlinks') }}" class="btn secondary scan-btn">
            {{ "Start New Scan"|t('broken-links') }}
        </a>
    </div>

    <style>

        .widget-header {
            margin-bottom: 12px;
        }
        
        .widget-header h2 {
            margin: 0 0 4px 0;
            padding: 0;
            font-size: 18px;
            font-weight: bold;
        }
        
        .widget-header .broken-count {
            color: #8f98a3;
            font-size: 14px;
        }
        
        .widget-status {
            margin-bottom: 16px;
        }
        
        .widget-status .status {
            margin-bottom: 4px;
            font-weight: 500;
            font-size: 14px;
            background-color: aqua;
            width: 5px;
            height: 5px;
        }
        
        .widget-status .status span[data-icon] {
            margin-right: 8px;
            
        }
        
        .widget-status .status.running {
            color: #3d7afc;
        }
        
        .widget-status .status.warning {
            color: #e27730;
            width: 100%;
            display: inline-block;
        }
        
        .widget-status .status.good {
            color: #27ab83;
        }
        
        .widget-status .details {
            color: #8f98a3;
            font-size: 13px;
        }
        
        .widget-links h3 {
            font-size: 14px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #576e7a;
            margin: 8px 0 8px 0;
            padding: 0;
        }
        
        .widget-links ul {
            margin: 0;
            padding: 0;
            list-style: none;
            border: 1px solid #e3e5e8;
            border-radius: 4px;
            overflow: hidden;
        }
        
        .widget-links li {
            border-top: 1px solid #f3f4f6;
            padding: 10px 12px;
            background-color: #fbfcfd;
        }
        
        .widget-links li:hover {
            background-color: #f3f7fc;
        }
        
        .widget-links li:first-child {
            border-top: none;
        }
        
        .link-url {
            display: block;
            color: #3d7afc;
            text-decoration: none;
            font-size: 14px;
            margin-bottom: 6px;
            word-break: break-all;
            font-weight: 500;
        }
        
        .link-url:hover {
            text-decoration: underline;
        }
        
        .link-details {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 13px;
        }
        
        .status-pill {
            background-color: #FEECDC;
            color: #C05621;
            padding: 3px 8px;
            border-radius: 3px;
            font-size: 12px;
            font-weight: 500;
        }
        
        .occurrence {
            color: #8f98a3;
            font-size: 12px;
        }
        
        .view-all {
            display: block;
            margin-top: 12px;
            text-align: center;
            color: #3d7afc;
            font-size: 14px;
            text-decoration: none;
            font-weight: 500;
        }
        
        .view-all:hover {
            text-decoration: underline;
        }
        
        .scan-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 20px;
            width: 100%;
            height: 36px;
            font-weight: 500;
        }
    </style>
{% else %}
    <div class="broken-links-widget">
        <a href="{{ cpUrl('brokenlinks') }}" class="btn secondary scan-btn">
            {{ "Start First Scan"|t('broken-links') }}
        </a>
    </div>
    <style>
        /* Include the same styles as above */
        .broken-links-widget {
            text-align: center;
        }
        
        .widget-header h2 {
            margin: 0 0 4px 0;
            padding: 0;
            font-size: 18px;
            font-weight: bold;
        }
        
        .widget-status {
            margin-bottom: 16px;
        }
        
        .widget-status .status {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 4px;
            font-weight: 500;
        }
        
        .widget-status .status.neutral {
            color: #8f98a3;
        }
        
        .scan-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 20px;
            width: 100%;
            height: 36px;
            font-weight: 500;
        }
    </style>
{% endif %}