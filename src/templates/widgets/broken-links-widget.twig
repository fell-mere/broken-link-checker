{% if latestScan %}
    <div class="broken-links-widget">
        <div class="widget-status">
            <div class="details">
                {{ "Last scan:"|t('broken-links') }} {{ latestScan.endTime ? latestScan.endTime|datetime('short') : "In progress"|t('broken-links') }}
            </div>
        </div>

        {% if brokenLinks|length > 0 %}
            <div class="widget-links">
                <h3>{{ "Recent Broken Links"|t('broken-links') }}</h3>
                <ul>
                    {% for link in brokenLinks %}
                        <li>
                            {% if link.url starts with 'http://' or link.url starts with 'https://' %}
                                <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer" class="link-url" title="{{ link.url }}">{{ link.url|length > 40 ? link.url|slice(0, 40) ~ '...' : link.url }}</a>
                            {% else %}
                                <span class="link-url" title="{{ link.url }}">{{ link.url|length > 40 ? link.url|slice(0, 40) ~ '...' : link.url }}</span>
                            {% endif %}
                            <div class="link-details">
                                <span class="status-pill">{{ link.status }}</span>
                            </div>
                        </li>
                    {% endfor %}
                </ul>

                {% if totalBrokenLinks > limit %}
                    <a href="{{ cpUrl('brokenlinks') }}" class="view-all">
                        {{ "View all {count} broken links"|t('broken-links', {count: totalBrokenLinks}) }}
                    </a>
                {% endif %}
            </div>
        {% endif %}

        <a href="{{ cpUrl('brokenlinks') }}" class="btn secondary scan-btn">
            {{ "Start New Scan"|t('broken-links') }}
        </a>
    </div>
{% else %}
    <div class="broken-links-widget broken-links-widget--centered">
        <a href="{{ cpUrl('brokenlinks') }}" class="btn secondary scan-btn">
            {{ "Start First Scan"|t('broken-links') }}
        </a>
    </div>
{% endif %}
