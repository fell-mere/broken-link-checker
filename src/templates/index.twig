{# This extends the main control panel layout from Craft CMS, ensuring consistent page design and structure #}
{% extends "_layouts/cp.twig" %}

{# Set the page title displayed in the browser tab and Craft control panel header #}
{% set title = "Broken Links"|t('broken-links') %}

{# Register the plugin's CP asset bundle (styles + index-page JS) #}
{% do craft.app.view.registerAssetBundle('craigclement\\craftbrokenlinks\\web\\assets\\BrokenLinksAsset') %}

{# Expose endpoints + active-scan state to the JavaScript #}
{% do craft.app.view.registerJsVar('BrokenLinksConfig', {
    startScanUrl: cpUrl('brokenlinks/start-scan'),
    clearDataUrl: cpUrl('brokenlinks/clear-data'),
    scanStatusUrl: cpUrl('brokenlinks/scan-status'),
    activeScanId: (latestScan and latestScan.status in ['pending', 'running']) ? latestScan.id : null,
}) %}

{# Make the JS-facing strings available to Craft.t() #}
{% do craft.app.view.registerTranslations('broken-links', [
    'Starting scan...',
    'Scan started successfully! The process will run in the background.',
    'Error',
    'Clearing data...',
    'All data cleared successfully!',
    'A scan is currently in progress...',
    'Are you sure you want to clear all broken links data? This cannot be undone.',
]) %}

{% block content %}
    <div class="broken-links-container">

        {# Display scan status and statistics if available #}
        {% if latestScan %}
            <div class="pane status-pane">
                <div class="scan-status-strip {% if latestScan.status == 'completed' %}completed{% elseif latestScan.status == 'failed' %}failed{% else %}running{% endif %}"></div>

                <div class="status-header">
                    <h2>{{ "Scan Status"|t('broken-links') }}</h2>
                </div>

                <div class="scan-stats-grid">
                    <div class="scan-stat-item">
                        <div class="scan-stat-label">{{ "Start Time"|t('broken-links') }}</div>
                        <div class="scan-stat-value">{{ latestScan.startTime|date('Y-m-d H:i:s') }}</div>
                    </div>

                    <div class="scan-stat-item">
                        <div class="scan-stat-label">{{ "End Time"|t('broken-links') }}</div>
                        <div class="scan-stat-value">
                            {% if latestScan.endTime %}
                                {{ latestScan.endTime|date('Y-m-d H:i:s') }}
                            {% else %}
                                -
                            {% endif %}
                        </div>
                    </div>

                    <div class="scan-stat-item">
                        <div class="scan-stat-label">{{ "URLs Scanned"|t('broken-links') }}</div>
                        <div class="scan-stat-value">{{ latestScan.totalUrlsScanned }}</div>
                    </div>

                    <div class="scan-stat-item">
                        <div class="scan-stat-label">{{ "Broken Links Found"|t('broken-links') }}</div>
                        <div class="scan-stat-value">{{ latestScan.totalBrokenLinks }}</div>
                    </div>
                </div>
            </div>
        {% endif %}

        {# Container for the action buttons #}
        <div class="buttons">
            <button id="start-scan" class="btn submit">{{ "Start New Scan"|t('broken-links') }}</button>
            <button id="force-scan" class="btn">{{ "Force Full Scan"|t('broken-links') }}</button>
            <button id="show-advanced" class="btn secondary">{{ "Advanced Options"|t('broken-links') }}</button>
            <a href="{{ cpUrl('utilities/queue-manager') }}" class="btn secondary" target="_blank" rel="noopener noreferrer">{{ "View Queue"|t('broken-links') }}</a>
            <div class="flex-spacer"></div>
            <button id="clear-data" class="btn delete">{{ "Clear All Data"|t('broken-links') }}</button>
            <div id="loading" class="loading-text"></div>
            <div id="loading-spinner" class="spinner hidden"></div>
        </div>

        {# Advanced options panel (hidden by default) #}
        <div id="advanced-options" class="pane advanced-options hidden">
            <div class="pane-header">
                <h2>{{ "Advanced Options"|t('broken-links') }}</h2>
            </div>
            <div class="pane-body">
                <div class="field">
                    <div class="heading">
                        <label for="batch-size">{{ "Batch Size"|t('broken-links') }}</label>
                        <div class="instructions"><p>{{ "Maximum number of entries to process in each batch"|t('broken-links') }}</p></div>
                    </div>
                    <div class="input">
                        <input type="number" id="batch-size" class="text" min="10" max="500" value="100">
                    </div>
                </div>
                <button id="toggle-advanced" class="btn secondary">{{ "Hide Advanced Options"|t('broken-links') }}</button>
            </div>
        </div>

        {# Section for displaying broken links #}
        <div id="results">
            {% if brokenLinks|length > 0 %}
                <h2>{{ "Broken Links"|t('broken-links') }}
                    <span class="count-badge">{{ totalBrokenLinks }}</span>
                </h2>

                <div class="export-buttons">
                    <a href="{{ cpUrl('brokenlinks/export', {'format': 'csv'}) }}" class="btn secondary" download>
                        <span data-icon="download"></span> {{ "Export CSV"|t('broken-links') }}
                    </a>
                    <a href="{{ cpUrl('brokenlinks/export', {'format': 'json'}) }}" class="btn secondary" download>
                        <span data-icon="download"></span> {{ "Export JSON"|t('broken-links') }}
                    </a>
                </div>

                <div class="tableview">
                    <table class="data fullwidth">
                        <thead>
                            <tr>
                                <th>{{ "Broken Link"|t('broken-links') }}</th>
                                <th>{{ "Status"|t('broken-links') }}</th>
                                <th>{{ "Link Text"|t('broken-links') }}</th>
                                <th>{{ "Page URL"|t('broken-links') }}</th>
                                <th>{{ "Entry"|t('broken-links') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for link in brokenLinks %}
                                <tr>
                                    <td>
                                        {% if link.url starts with 'http://' or link.url starts with 'https://' %}
                                            <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer" title="{{ link.url }}">{{ link.url }}</a>
                                        {% else %}
                                            {{ link.url }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="status-pill {{ link.status|lower }}">{{ link.status }}{% if link.statusCode %} ({{ link.statusCode }}){% endif %}</span>
                                    </td>
                                    <td>
                                        {{ link.linkText ?: 'N/A' }}
                                    </td>
                                    <td>
                                        {% if link.pageUrl starts with 'http://' or link.pageUrl starts with 'https://' %}
                                            <a href="{{ link.pageUrl }}" target="_blank" rel="noopener noreferrer" title="{{ link.pageUrl }}">
                                                {{ link.pageUrl|replace({'http://': '', 'https://': ''}) }}
                                            </a>
                                        {% else %}
                                            {{ link.pageUrl }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if link.entryId %}
                                            <a href="{{ cpUrl('entries/edit/' ~ link.entryId) }}" target="_blank" rel="noopener noreferrer">{{ link.entryTitle ?: 'N/A' }}</a>
                                        {% else %}
                                            N/A
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% elseif latestScan %}
                <div class="no-results">
                    <p>{{ "No broken links found in the last scan."|t('broken-links') }}</p>
                </div>
            {% else %}
                <div class="no-results">
                    <p>{{ "No scan has been run yet. Click \"Start New Scan\" to check your site for broken links."|t('broken-links') }}</p>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
